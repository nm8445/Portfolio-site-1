---
layout: layouts/default.njk
title: Jobsite Page
---

<div class="container py-5">
  <div class="row align-items-center">

    <!-- Left Side: Screenshot Carousel -->
    <div class="col-lg-6 pe-lg-7">
      <div class="image-container">
        <div id="screenshotCarousel" class="carousel slide" data-bs-ride="carousel">
          <div class="carousel-inner">
            <!-- First image -->
            <div class="carousel-item active">
              <img src="/src/image/jobs_page.png" class="img-fluid" alt="Trading Bot Screenshot 1">
            </div>
            <!-- Second image -->
            <div class="carousel-item">
              <img src="/src/image/personal_info_page.png" class="img-fluid" alt="Trading Bot Screenshot 2">
            </div>
            <!-- Third image -->
            <div class="carousel-item">
              <img src="/src/image/resume_upload_page.png" class="img-fluid" alt="Trading Bot Screenshot 2">
            </div>
            
          </div>

          <!-- Carousel arrows -->
          <button class="carousel-control-prev" type="button" data-bs-target="#screenshotCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#screenshotCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Right Side: Text -->
    <div class="col-lg-6">
      <div class="text-container text-light">
        <h2 class="mb-3">Get Hired</h2>
        <p>
         This website was created to make the Durham College Hired Portal more user-friendly and efficient. 
         It was built using 11ty, Nunjucks, and JavaScript, with MongoDB integration for data storage. 
         Users can sign up, with their information securely stored in the database and passwords hashed. 
         They can also log in, apply for jobs, and track which positions they have applied to.
        </p>

        <h5 class="mt-4">Technologies used</h5>
        <ul>
          <li>Nunjucks</li>
          <li>HTML</li>
          <li>JSON</li>
          <li>11ty</li>
          <li>CSS</li>
          <li>Bootstrap</li>
          <li>MongoDB</li>
          <li>JavaScript</li>
          <li>Node.js</li>
          <li>Express</li>
        </ul>
      </div>
    </div>

  </div>
</div>
